    type: 2}
  udonAssembly: ".data_start\r\n\r\n    .export teleportTo\r\n    .export SFX\r\n   
    \r\n    __instance_0: %VRCSDKBaseVRCPlayerApi, null\r\n    __teleportPos_0: %UnityEngineVector3,
    null\r\n    __teleportRot_0: %UnityEngineQuaternion, null\r\n    onPlayerTriggerEnterPlayer:
    %VRCSDKBaseVRCPlayerApi, null\r\n    __instance_1: %UnityEngineTransform, this\r\n   
    __instance_3: %UnityEngineTransform, this\r\n    __instance_2: %UnityEngineGameObject,
    this\r\n    __instance_4: %UnityEngineAudioSource, null\r\n    teleportTo: %UnityEngineGameObject,
    this\r\n    SFX: %UnityEngineAudioSource, null\r\n    time: %UnityEngineTime,
    null\r\n    newVariable: %SystemRandom, null\r\n\r\n.data_end\r\n\r\n.code_start\r\n\r\n   
    .export _onPlayerTriggerEnter\r\n    \r\n    _onPlayerTriggerEnter:\r\n    \r\n       
    PUSH, onPlayerTriggerEnterPlayer\r\n        PUSH, __instance_0\r\n        COPY\r\n       
    PUSH, teleportTo\r\n        PUSH, __instance_2\r\n        COPY\r\n        PUSH,
    __instance_2\r\n        PUSH, __instance_1\r\n        EXTERN, \"UnityEngineGameObject.__get_transform__UnityEngineTransform\"\r\n       
    PUSH, __instance_1\r\n        PUSH, __teleportPos_0\r\n        EXTERN, \"UnityEngineTransform.__get_position__UnityEngineVector3\"\r\n       
    PUSH, teleportTo\r\n        PUSH, __instance_2\r\n        COPY\r\n        PUSH,
    __instance_1\r\n        PUSH, __instance_3\r\n        COPY\r\n        PUSH, __instance_1\r\n       
    PUSH, __teleportRot_0\r\n        EXTERN, \"UnityEngineTransform.__get_rotation__UnityEngineQuaternion\"\r\n       
    PUSH, __instance_0\r\n        PUSH, __teleportPos_0\r\n        PUSH, __teleportRot_0\r\n       
    EXTERN, \"VRCSDKBaseVRCPlayerApi.__TeleportTo__UnityEngineVector3_UnityEngineQuaternion__SystemVoid\"\r\n       
    PUSH, SFX\r\n        PUSH, __instance_4\r\n        COPY\r\n        PUSH, __instance_4\r\n       
    EXTERN, \"UnityEngineAudioSource.__Play__SystemVoid\"\r\n        JUMP, 0xFFFFFFFC\r\n   
    \r\n\r\n.code_end\r\n"
